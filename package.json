{
  "name": "yt-dlp-studio",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "main": "dist-electron/main.js",
  "description": "A polished Electron front-end for yt-dlp using the shared conda environment.",
  "author": "Dyifo",
  "scripts": {
    "dev:web": "vite",
    "dev:electron": "node scripts/dev-electron.mjs",
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "build:web": "tsc -b && vite build --base ./",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:web && npm run build:electron",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "electron .",
    "launch:mac": "zsh scripts/launch-mac.sh",
    "dist": "npm run build && electron-builder",
    "dist:mac": "zsh scripts/build-mac-share.sh",
    "dist:win": "zsh scripts/build-win-share.sh",
    "dist:share": "powershell -ExecutionPolicy Bypass -File scripts/build-shareable-package.ps1"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.codex.ytdlpstudio",
    "productName": "YT-DLP Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "electron/preload.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "tools",
        "to": "tools",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": "portable"
    },
    "mac": {
      "category": "public.app-category.video",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
